pipeline {
  agent any

  environment {
    AWS_REGION = 'us-east-1'
    ACCOUNT_ID = '561848282182'

    // ECR repo (full image repo URL without tag)
    ECR_REPO   = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/chai-kafe-app"

    // Image tag for this build
    IMAGE_TAG  = "${BUILD_NUMBER}"

    // GitOps repo details (same repo)
    GIT_REPO_NAME   = "chaikafe.in"
    GIT_USER_NAME   = "rakeshkumar2398"
    GIT_REPO_URL    = "https://github.com/rakeshkumar2398/chaikafe.in.git"
    DEPLOYMENT_FILE = "k8s/deployment.yaml"
  }

  stages {

    stage('Git Checkout') {
      steps {
        git branch: 'main', url: "${GIT_REPO_URL}"
      }
    }

    stage('Build Application') {
      steps {
        sh 'mvn -B clean package -DskipTests'
      }
    }

    stage('SonarQube Scan') {
      steps {
        withSonarQubeEnv('sonar-token') {
          sh 'mvn -B sonar:sonar'
        }
      }
    }

    stage('Quality Gate') {
      steps {
        timeout(time: 5, unit: 'MINUTES') {
          waitForQualityGate abortPipeline: true
        }
      }
    }

    stage('Docker Build Image') {
      steps {
        sh 'docker build -t chaikafe.in-app:${IMAGE_TAG} .'
      }
    }

    stage('Trivy Image Scan') {
      steps {
        sh """
          mkdir -p /data/trivy-cache

          docker run --rm \
            -v /var/run/docker.sock:/var/run/docker.sock \
            -v /data/trivy-cache:/root/.cache/trivy \
            aquasec/trivy:latest image \
            --severity HIGH,CRITICAL \
            --exit-code 1 \
            --no-progress \
            chaikafe.in-app:${IMAGE_TAG}
        """
      }
    }

    stage('Amazon ECR Login') {
      steps {
        sh """
          aws ecr get-login-password --region ${AWS_REGION} \
          | docker login --username AWS --password-stdin ${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
        """
      }
    }

    stage('Docker Tag') {
      steps {
        sh 'docker tag chaikafe.in-app:${IMAGE_TAG} ${ECR_REPO}:${IMAGE_TAG}'
      }
    }

    stage('Docker Push') {
      steps {
        sh 'docker push ${ECR_REPO}:${IMAGE_TAG}'
      }
    }

    stage('Update Deployment File (GitOps for ArgoCD)') {
      steps {
        echo 'Updating k8s/deployment.yaml with new image tag and pushing to GitHub'

        withCredentials([usernamePassword(
          credentialsId: 'github-creds',
          usernameVariable: 'GIT_USER',
          passwordVariable: 'GIT_TOKEN'
        )]) {
          sh """
            if [ ! -f "${DEPLOYMENT_FILE}" ]; then
              echo "ERROR: ${DEPLOYMENT_FILE} not found"
              exit 1
            fi

            git config user.email "jenkins@chaikafe.in"
            git config user.name  "Jenkins CI"

            echo "Before update:"
            grep -n "image:" ${DEPLOYMENT_FILE} || true

            # Update image line to match what we pushed to ECR
            sed -i "s#^\\\\s*image:.*#          image: ${ECR_REPO}:${IMAGE_TAG}#g" ${DEPLOYMENT_FILE}

            echo "After update:"
            grep -n "image:" ${DEPLOYMENT_FILE} || true

            git add ${DEPLOYMENT_FILE}
            git commit -m "deploy: update image to ${IMAGE_TAG}" || true
            git push https://${GIT_USER}:${GIT_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
          """
        }
      }
    }
  }
}
